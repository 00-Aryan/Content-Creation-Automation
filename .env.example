# ==============================================================================
# Content Creation Automation — Environment Configuration Template
# Copy this file to '.env' and fill in your actual API keys and preferences.
# DO NOT COMMIT THE ACTUAL '.env' FILE TO VERSION CONTROL.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. API Keys & Credentials (Keep these secret!)
# ------------------------------------------------------------------------------

# Google Gemini API Key (Required for content generation/synthesis)
# Retrieve from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (Optional; used as fallback provider for inference)
# Retrieve from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key (Optional; used for speed-optimized model execution)
# Retrieve from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Supabase Client Settings (Optional; only if postgres remote DB is enabled)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_role_or_anon_key_here

# ------------------------------------------------------------------------------
# 2. Application Context & Environment Settings
# ------------------------------------------------------------------------------

# Environment: 'development', 'staging', or 'production'
# Controls log formatting and safety behaviors.
CONTENT_CREATION_ENV=development

# Logging Level: 'DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL'
LOG_LEVEL=INFO

# Root directory for file-system storage (data, configs, templates)
# If not set, defaults to the project root directory.
CONTENT_FACTORY_ROOT=
